<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Plugin de traccion diferencial -->
  <!-- Convierte comandos /cmd_vel en velocidades de cada rueda -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>Rueda_izquierda_joint</left_joint>
      <right_joint>Rueda_derecha_joint</right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>
  </gazebo>

  <!-- Plugin publicador de estado de joints -->
  <!-- Publica las posiciones de cada joint para que robot_state_publisher actualice el TF -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <joint_name>Rueda_izquierda_joint</joint_name>
      <joint_name>Rueda_derecha_joint</joint_name>
      <joint_name>Base_castor_joint</joint_name>
      <joint_name>Rueda_castor_joint</joint_name>
    </plugin>
  </gazebo>

  <!-- Plugin del sensor LIDAR -->
  <!-- Plugin de sensores, va a nivel de modelo (sin reference) -->
  <gazebo>
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
  </gazebo>

  <!-- Sensor LIDAR asociado al link -->
  <!-- <gazebo reference="Lidar_link">
    <sensor name="gpu_lidar" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
