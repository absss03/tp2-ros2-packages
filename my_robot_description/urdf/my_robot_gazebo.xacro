      <update_rate>2</update_rate>
      <gz_frame_id>Lidar_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>180</samples>
            <resolution>1.0</resolution>
            <min_angle>0.0</min_angle>
