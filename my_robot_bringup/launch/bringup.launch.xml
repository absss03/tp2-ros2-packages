<launch>

  <set_env name="GZ_SIM_RESOURCE_PATH"
           value="$(find-pkg-share my_robot_description)/.."/>

  <!-- Rutas a los archivos -->
  <let name="urdf_path"
       value="$(find-pkg-share my_robot_description)/urdf/my_robot.urdf.xacro"/>
  <let name="rviz_config_path"
       value="$(find-pkg-share my_robot_description)/rviz/urdf_config.rviz"/>
  <let name="gazebo_bridge_path"
       value="$(find-pkg-share my_robot_bringup)/config/gazebo_bridge.yaml"/>
  <let name="world_path"
       value="$(find-pkg-share my_robot_bringup)/worlds/maze.world"/>

  <!-- 1. robot_state_publisher: lee el URDF y publica el TF del robot -->
  <node pkg="robot_state_publisher" exec="robot_state_publisher">
    <param name="robot_description"
           value="$(command 'xacro $(var urdf_path)')"/>
    <param name="use_sim_time" value="True"/>
  </node>

  <!-- 2. Gazebo: lanza el simulador con un mundo vacio -->
  <!-- <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
    <arg name="gz_args" value="-r empty.sdf"/>
  </include>  -->
  <!-- 2. Gazebo: lanza el simulador con laberinto maze-->
  <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
    <arg name="gz_args" value="-r $(var world_path)"/>
  </include>


  <!-- 3. Spawn: carga el modelo del robot en Gazebo -->
  <node pkg="ros_gz_sim" exec="create"
        args="-topic robot_description -x -2.025 -y 3.150 -z 0.1 -Y -1.5708"/>

  <!-- 4. Bridge: conecta topicos entre ROS y Gazebo -->
  <node pkg="ros_gz_bridge" exec="parameter_bridge">
    <param name="config_file" value="$(var gazebo_bridge_path)"/>
  </node>

  <!-- 5. RViz: visualizacion -->
  <node pkg="rviz2" exec="rviz2" output="screen"
        args="-d $(var rviz_config_path)"/>

</launch>